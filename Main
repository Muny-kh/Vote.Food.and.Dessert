<body>

    <header>
        <h1>បោះឆ្នោតមុខម្ហូប 🍔🔥</h1>
        <button class="admin-trigger-btn" onclick="toggleAdminMode()" id="adminBtn">
            ✏️ Admin Edit
        </button>
    </header>

    <div class="deadline-box" id="countdown">ការបោះឆ្នោតបើកជានិច្ច</div>
    <br>

    <div class="container" id="mainContainer">
        
        <div id="adminSection" style="flex-direction: column; gap: 30px;">
            <div class="card">
                <h2>ផ្ទាំងគ្រប់គ្រង (Admin) 🛠️</h2>
                <div class="form-group">
                    <label>ឈ្មោះមុខម្ហូប៖</label>
                    <input type="text" id="foodName" placeholder="ឧ. បាយសាច់ជ្រូក, ញាំមី...">
                </div>
                <div class="form-group">
                    <label>តំណភ្ជាប់រូបភាព (URL)៖</label>
                    <input type="text" id="foodImg" placeholder="https://example.com/image.jpg">
                </div>
                <button onclick="addFood()">បញ្ចូលមុខម្ហូបថ្មី</button>
                
                <hr style="margin: 20px 0; border: 1px dashed #1a1a2e;">
                
                <div class="form-group">
                    <label>កំណត់ថ្ងៃផុតកំណត់ (Deadline)៖</label>
                    <input type="date" id="deadlineDate">
                </div>
                <div class="form-group">
                    <label>កំណត់ម៉ោង៖</label>
                    <input type="time" id="deadlineTime">
                </div>
                <button onclick="setDeadline()" style="background: #1a1a2e;">រក្សាទុក Deadline</button>
                
                <button onclick="logoutAdmin()" style="background: #777; margin-top: 15px;">ចាកចេញពី Admin 🔒</button>
            </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 30px;">
            
            <div class="card">
                <h2>តំបន់បោះឆ្នោតរបស់សិស្ស (Student Vote) 🗳️✨</h2>
                <br>
                <div class="food-grid" id="foodContainer">
                    </div>
            </div>

            <div class="card">
                <h2>លទ្ធផលបច្ចុប្បន្ន (Dashboard) 📊</h2>
                <div id="leaderboard">
                    </div>
            </div>

        </div>

    </div>

    <script>
        // ពាក្យសម្ងាត់សម្រាប់ Admin (អ្នកអាចដូរពាក្យ "admin123" នេះចេញបាន)
        const ADMIN_PASSWORD = "admin123";
        let isAdminLoggedIn = false;

        // ទិន្នន័យចាប់ផ្តើមគឺទទេស្អាត
        let foods = [];
        let deadlineTime = null;
        let timerInterval = null;

        // មុខងារបង្ហាញទិន្នន័យលើអេក្រង់
        function render() {
            const container = document.getElementById('foodContainer');
            const leaderboard = document.getElementById('leaderboard');
            
            container.innerHTML = '';
            leaderboard.innerHTML = '';

            // ប្រសិនបើមិនទាន់មានមុខម្ហូប
            if (foods.length === 0) {
                container.innerHTML = `<div class="empty-message">មិនទាន់មានមុខម្ហូបសម្រាប់បោះឆ្នោតឡើយ។ សូមឱ្យ Admin បញ្ចូលមុខម្ហូបជាមុនសិន!</div>`;
                leaderboard.innerHTML = `<div class="empty-message">មិនទាន់មានលទ្ធផលនៅឡើយទេ</div>`;
                return;
            }

            // បង្ហាញកាតមុខម្ហូប
            foods.forEach(food => {
                container.innerHTML += `
                    <div class="food-item">
                        <button class="delete-btn" style="display: ${isAdminLoggedIn ? 'block' : 'none'}" onclick="deleteFood(${food.id})">លុប ❌</button>
                        <img src="${food.image}" class="food-img" alt="${food.name}" onerror="this.src='https://placehold.co/400x300?text=%E1%9E%9FullPath+Error'">
                        <div class="food-info">
                            <h3>${food.name}</h3>
                            <button class="vote-btn" onclick="vote(${food.id})">បោះឆ្នោត 💖</button>
                        </div>
                    </div>
                `;
            });

            // បង្ហាញលទ្ធផលនៅលើ Dashboard
            const sortedFoods = [...foods].sort((a, b) => b.votes - a.votes);
            sortedFoods.forEach(food => {
                leaderboard.innerHTML += `
                    <div class="leaderboard-item">
                        <span>${food.name}</span>
                        <span class="vote-count">${food.votes} សំឡេង</span>
                    </div>
                `;
            });
        }

        // មុខងារត្រួតពិនិត្យ និង បើក/បិទ Admin Mode
        function toggleAdminMode() {
            if (!isAdminLoggedIn) {
                const passwordInput = prompt("សូមបញ្ចូលពាក្យសម្ងាត់ដើម្បីចូលទៅកាន់ផ្ទាំង Admin៖");
                if (passwordInput === ADMIN_PASSWORD) {
                    isAdminLoggedIn = true;
                    document.getElementById('adminSection').style.display = 'flex';
                    document.getElementById('mainContainer').classList.add('admin-mode');
                    document.getElementById('adminBtn').innerHTML = "🔒 របៀប Admin កំពុងបើក";
                    document.getElementById('adminBtn').style.background = "#33ffcc";
                    render(); // ដើម្បីបង្ហាញប៊ូតុងលុបលើមុខម្ហូប
                    alert("ការចូលទៅកាន់ផ្ទាំង Admin បានជោគជ័យ!");
                } else if (passwordInput !== null) {
                    alert("ពាក្យសម្ងាត់មិនត្រឹមត្រូវទេ! សិស្សមិនអាចកែប្រែបានឡើយ។");
                }
            } else {
                logoutAdmin();
            }
        }

        // មុខងារចាកចេញពី Admin
        function logoutAdmin() {
            isAdminLoggedIn = false;
            document.getElementById('adminSection').style.display = 'none';
            document.getElementById('mainContainer').classList.remove('admin-mode');
            document.getElementById('adminBtn').innerHTML = "✏️ Admin Edit";
            document.getElementById('adminBtn').style.background = "#fff";
            render();
        }

        // មុខងារ Admin បន្ថែមមុខម្ហូប
        function addFood() {
            const nameInput = document.getElementById('foodName');
            const imgInput = document.getElementById('foodImg');

            if (nameInput.value.trim() === "") {
                alert("សូមបញ្ចូលឈ្មោះមុខម្ហូបផង!");
                return;
            }

            const newFood = {
                id: Date.now(),
                name: nameInput.value,
                image: imgInput.value || 'https://placehold.co/400x300?text=No+Image',
                votes: 0
            };

            foods.push(newFood);
            nameInput.value = '';
            imgInput.value = '';
            render();
        }

        // មុខងារ Admin លុបមុខម្ហូប
        function deleteFood(id) {
            if(confirm("តើអ្នកពិតជាចង់លុបមុខម្ហូបនេះមែនទេ?")) {
                foods = foods.filter(f => f.id !== id);
                render();
            }
        }

        // មុខងារសិស្សបោះឆ្នោត
        function vote(id) {
            if (deadlineTime && new Date() > deadlineTime) {
                alert("⏰ សោកស្តាយផង! ការបោះឆ្នោតត្រូវបានបិទហើយ ព្រោះហួសកាលកំណត់ (Deadline)។");
                return;
            }
            
            const food = foods.find(f => f.id === id);
            if (food) {
                food.votes++;
                render();
            }
        }

        // មុខងារកំណត់ Deadline
        function setDeadline() {
            const dateInput = document.getElementById('deadlineDate').value;
            const timeInput = document.getElementById('deadlineTime').value;

            if (!dateInput || !timeInput) {
                alert("សូមបំពេញថ្ងៃ និងម៉ោងឱ្យបានត្រឹមត្រូវ!");
                return;
            }

            deadlineTime = new Date(`${dateInput}T${timeInput}`);
            alert("បានកំណត់កាលបរិច្ឆេទផុតកំណត់រួចរាល់!");
            
            if (timerInterval) clearInterval(timerInterval);
            updateCountdown();
        }

        // មុខងាររាប់ថយក្រោយ (Countdown)
        function updateCountdown() {
            if (!deadlineTime) return;

            timerInterval = setInterval(() => {
                const now = new Date();
                const diff = deadlineTime - now;

                if (diff <= 0) {
                    document.getElementById('countdown').innerText = "⏱️ ការបោះឆ្នោតត្រូវបានបិទ! (ហួស Deadline)";
                    document.getElementById('countdown').style.background = "#777";
                    clearInterval(timerInterval);
                    return;
                }

                const hours = Math.floor(diff / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((diff % (1000 * 60)) / 1000);

                document.getElementById('countdown').innerText = `⏱️ រយៈពេលនៅសល់៖ ${hours}ម៉ោង ${minutes}នាទី ${seconds}វិ`;
                document.getElementById('countdown').style.background = "#ff3366";
            }, 1000);
        }

        // ដំណើរការដំបូង
        render();
    </script>
</body>
</html>