            color: white;
            padding: 8px 15px;
            border-radius: 20px;
            border: 2px solid var(--dark-color);
            text-align: center;
            margin: 15px auto 0 auto;
            max-width: fit-content;
        }

        .container {
            display: grid;
            grid-template-columns: 1fr;
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* នៅពេលដែល Admin ឡុកចូល នឹងប្តូរ Layout ទៅជា ២ជួរ */
        .container.admin-mode {
            @media (min-width: 992px) {
                grid-template-columns: 1fr 2fr;
            }
        }

        /* Card Base Style */
        .card {
            background: var(--card-bg);
            border: var(--border-style);
            box-shadow: 6px 6px 0px #1a1a2e;
            border-radius: 16px;
            padding: 20px;
            transition: transform 0.2s;
        }

        .card h2 {
            margin-bottom: 15px;
            border-bottom: 2px dashed #1a1a2e;
            padding-bottom: 8px;
            font-size: 1.5rem;
        }

        /* Admin Section (លាក់ទុកជាមុន) */
        #adminSection {
            display: none;
        }

        /* Form Style */
        .form-group {
            margin-bottom: 15px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-weight: 600;
        }

        input[type="text"], input[type="date"], input[type="time"] {
            width: 100%;
            padding: 12px;
            border: var(--border-style);
            border-radius: 8px;
            font-size: 1rem;
            background: #fff;
        }

        button {
            width: 100%;
            padding: 12px;
            background: var(--main-color);
            color: white;
            border: var(--border-style);
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 3px 3px 0px #1a1a2e;
            transition: all 0.1s;
        }

        button:active {
            transform: translate(3px, 3px);
            box-shadow: 0px 0px 0px #1a1a2e;
        }

        /* Food Grid & Cards */
        .food-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 20px;
        }

        .food-item {
            background: #fff;
            border: var(--border-style);
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
        }

        .food-img {
            width: 100%;
            height: 150px;
            object-fit: cover;
            border-bottom: var(--border-style);
            background: #eef1f6;
        }

        .food-info {
            padding: 15px;
            text-align: center;
        }

        .vote-btn {
            background: var(--secondary-color);
            color: #1a1a2e;
            margin-top: 10px;
        }

        /* ប៊ូតុងលុបមុខម្ហូប (បង្ហាញតែពេល Admin ចូល) */
        .delete-btn {
            display: none;
            position: absolute;
            top: 10px;
            right: 10px;
            background: #ff3333;
            color: white;
            border: 2px solid #1a1a2e;
            padding: 5px 10px;
            border-radius: 8px;
            font-size: 0.8rem;
            cursor: pointer;
            width: auto;
            box-shadow: 2px 2px 0px #1a1a2e;
        }

        /* Dashboard Leaderboard */
        .leaderboard-item {
            display: flex;
